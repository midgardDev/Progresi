generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// Teacher model 
model Teacher {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  school       String
  phone        String?
  password     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relationships
  students     Student[]
  assessments  Assessment[]
}

// Student model 
model Student {
  id           String    @id @default(cuid())
  name         String
  grade        String    
  stream       String?   
  teacherId    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relationships
  teacher      Teacher   @relation(fields: [teacherId], references: [id])
  competencies CompetencyRecord[]
  assessmentResults AssessmentResult[]

}

// Competency Record 
model CompetencyRecord {
  id           String    @id @default(cuid())
  studentId    String
  subject      String    
  competency   String    
  level        Int       
  date         DateTime  @default(now())
  notes        String?
  createdAt    DateTime  @default(now())
  
  // Relationships
  student      Student   @relation(fields: [studentId], references: [id])
}

// Assessment 
model Assessment {
  id           String    @id @default(cuid())
  title        String
  subject      String
  date         DateTime
  teacherId    String
  createdAt    DateTime  @default(now())
  
  // Relationships
  teacher      Teacher   @relation(fields: [teacherId], references: [id])
  results      AssessmentResult[]
}

// Individual student result
model AssessmentResult {
  id           String    @id @default(cuid())
  assessmentId String
  studentId    String
  score        Int?      
  totalPossible Int?
  feedback     String?
  
  // Relationships
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  student      Student   @relation(fields: [studentId], references: [id])
}